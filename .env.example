# SalesOps OpenEnv — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ===========================================================================
# OPTION A: Hugging Face Inference API  [FREE — Recommended]
# ---------------------------------------------------------------------------
# 1. Go to https://huggingface.co/settings/tokens
# 2. Create a token with "Make calls to Inference Providers" permission
# 3. Paste it below as HF_TOKEN
#
# API_BASE_URL=https://api-inference.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
# HF_TOKEN=hf_your_token_here
# ===========================================================================

# ===========================================================================
# OPTION B: Groq  [FREE tier — ultra-fast Llama 3.3 70B]
# ---------------------------------------------------------------------------
# 1. Sign up at https://console.groq.com  (no credit card needed)
# 2. Generate an API key
#
# API_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.3-70b-versatile
# HF_TOKEN=gsk_your_groq_key_here
# ===========================================================================

# ===========================================================================
# OPTION C: OpenRouter  [FREE models available]
# ---------------------------------------------------------------------------
# 1. Sign up at https://openrouter.ai  (free credits on signup)
# 2. Use models like mistralai/mistral-7b-instruct:free
#
# API_BASE_URL=https://openrouter.ai/api/v1
# MODEL_NAME=mistralai/mistral-7b-instruct:free
# HF_TOKEN=sk-or-your_key_here
# ===========================================================================

# ---------------------------------------------------------------------------
# Active config — fill in ONE of the options above:
# ---------------------------------------------------------------------------

# === RECOMMENDED: Hugging Face (free with your HF account) ===
API_BASE_URL=https://api-inference.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=hf_your_token_here

# ---------------------------------------------------------------------------
# Optional: Docker image tag (used in inference.py metadata log)
# ---------------------------------------------------------------------------
IMAGE_NAME=salesops-openenv:latest

# ---------------------------------------------------------------------------
# Optional: Server port (default 7860 for HF Spaces)
# ---------------------------------------------------------------------------
PORT=7860
